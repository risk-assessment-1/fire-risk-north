---
import { getLangFromUrl, slugSelector } from "@/lib/utils/languageParser";
import { titleify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  locations: CollectionEntry<"locations">[];
  otherLocations?: CollectionEntry<"locations">[];
};

const { locations, otherLocations = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<section class="section pt-0">
  <div class="pb-4 bg-gray-white">
    <div class="container">
      <div class="flex justify-between items-center">
        <div class="section-title mb-0">
          <span class="section-title-border"></span>
          <p>Areas We Cover</p>
          <h2 class="ml-0!">Our Locations</h2>
        </div>
        <div class="hidden md:block mr-0!">
          <a
            href={slugSelector("/locations", lang)}
            class="btn btn-primary hover-ripple"
          >
            View All Locations
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <div
      class="locations-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-6"
    >
      {
        locations.map((location) => {
          const slug = location.id.split("/").pop();
          return (
            <div class="lg:col-span-2">
              <div class="box-shadow">
                <div class="p-6 bg-white dark:bg-darkmode-light">
                  <h3 class="heading h5">
                    <a
                      href={slugSelector(`/locations/${slug}`, lang)}
                      class="text-text-dark dark:text-darkmode-text-dark hover:text-primary dark:hover:text-darkmode-primary duration-200"
                    >
                      {titleify(slug || "")}
                    </a>
                  </h3>
                  <p class="mt-2 mb-4 line-clamp-2 text-text-dark/70 dark:text-darkmode-text-dark/70">
                    {location.data.description}
                  </p>
                  <a
                    href={slugSelector(`/locations/${slug}`, lang)}
                    class="pl-0 btn btn-arrow"
                  >
                    Read More{" "}
                    <span class="sr-only">about ${titleify(slug || "")}</span>
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>

    {
      otherLocations.length > 0 && (
        <p class="mt-8 text-center text-text-dark/70 dark:text-darkmode-text-dark/70">
          <span class="font-semibold text-text-dark dark:text-darkmode-text-dark">
            We also cover
          </span>{" "}
          {otherLocations.map((loc, i) => {
            const slug = loc.id.split("/").pop();
            return (
              <>
                {i > 0 && (i === otherLocations.length - 1 ? " and " : ", ")}
                <a
                  href={slugSelector(`/locations/${slug}`, lang)}
                  class="font-medium text-primary dark:text-darkmode-primary hover:underline"
                >
                  {titleify(slug || "")}
                </a>
              </>
            );
          })}
          <span> and surrounding areas.</span>
        </p>
      )
    }
  </div>
</section>

<style>
  @media (min-width: 1024px) {
    .locations-grid > div:last-child:nth-child(3n-2) {
      grid-column-end: 5;
    }

    .locations-grid > div:nth-last-child(2):nth-child(3n-2) {
      grid-column-end: 4;
    }
  }
</style>
