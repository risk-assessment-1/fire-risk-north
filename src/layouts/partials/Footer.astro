---
import Logo from "@/components/Logo.astro";
import Social from "@/components/Social.astro";
import config from "@/config/config.json";
import social from "@/config/social.json";
import {
  getLangFromUrl,
  getTranslations,
  slugSelector,
} from "@/lib/utils/languageParser";
import { markdownify, plainify } from "@/lib/utils/textConverter";

const lang = getLangFromUrl(Astro.url);
const menu = await getTranslations(lang as string);
let footer: string[] = [];
if (menu) {
  footer = menu.footer;
}

const { copyright, address, phone, email, footer_content, copyright_menu } =
  config.params;
const { services, contact_info, follow_us_on } = await getTranslations(
  lang as string,
);
---

<footer>
  <!-- main footer -->
  <div class="section bg-secondary dark:bg-darkmode-secondary">
    <div class="container">
      <div class="row justify-between">
        <!-- footer content -->
        <div class="md:col-5 mb-5 md:mb-0">
          <Logo src="/images/logo.png" />
          <p
            class="text-light/75 mt-6 mb-5"
            set:html={markdownify(footer_content)}
          />
          <!-- social links -->
          <p class="text-white mb-6 mt-12 text-h5 font-semibold">
            {follow_us_on}
          </p>
          <Social
            source={social.main}
            className="social-icons-topbar inline-block text-sm"
          />
        </div>

        <div class="md:col-6">
          <div class="row">
            <!-- service list -->
            <div class="col-6 mt-5">
              <p class="text-white mb-4 text-h5 font-semibold">{services}</p>
              <ul class="list-styled">
                {
                  footer.map((menu: any) => (
                    <li class="mb-3 text-light/75">
                      <a
                        class="block hover:text-primary-on-dark"
                        href={`${slugSelector(menu.url, lang)}`}
                        set:html={markdownify(menu.name)}
                      />
                    </li>
                  ))
                }
              </ul>
            </div>

            <!-- contact info -->
            <div class="col-6 mt-5">
              <p class="text-white mb-4 text-h5 font-semibold">
                {contact_info}
              </p>
              <ul>
                <li class="text-light/75 mb-3">
                  <a
                    class="hover:text-primary-on-dark"
                    aria-label={`Address: ${address}`}
                    target="_blank"
                    href={`https://www.google.com/maps?q=${encodeURIComponent(address)}`}
                    set:html={plainify(address)}
                  />
                </li>
                <li class="text-light/75 mb-3">
                  <a
                    class="hover:text-primary-on-dark"
                    href={`tel:${phone.replace(/\s/g, "")}`}
                    set:html={plainify(phone)}
                  />
                </li>
                <li class="text-light/75 mb-3">
                  <a
                    class="hover:text-primary-on-dark"
                    aria-label={`Email: ${email}`}
                    href={`mailto:${email}`}
                    set:html={plainify(email)}
                  />
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- copyright -->
  <div class="bg-[#1F2630] py-4">
    <div class="container">
      <div class="row">
        <div class="md:col-6 text-center md:text-start mb-3 md:mb-0">
          <p class="mb-0 text-primary-on-dark text-sm">
            <span
              class="text-primary-on-dark dark:text-darkmode-primary"
              set:html={markdownify(copyright)}
            />
            <span id="currentYear" class="mr-1"></span>
          </p>
          <script is:inline>
            var el = document.getElementById("currentYear");
            if (el) el.textContent = new Date().getFullYear().toString();
          </script>
        </div>

        {
          copyright_menu.enable && (
            <div class="md:col-6 text-center md:text-end text-sm">
              <ul class="list-inline">
                {copyright_menu?.menu_items?.map(
                  (menu: { name: string; url: string }, i: number) => (
                    <li class="inline mx-0">
                      <a
                        class={`inline-block px-3 text-light hover:text-primary duration-200 ${copyright_menu?.menu_items.length - 1 !== i ? "border-r" : ""}`}
                        href={menu.url}
                      >
                        {menu.name}
                      </a>
                    </li>
                  ),
                )}
              </ul>
            </div>
          )
        }
      </div>
    </div>
  </div>
</footer>
