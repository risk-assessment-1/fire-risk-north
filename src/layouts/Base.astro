---
import type { ImageMetadata } from "astro";
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { getLangFromUrl, stripHtmlExt } from "@/lib/utils/languageParser";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import {
  GoogleTagmanager,
  GoogleTagmanagerNoscript,
} from "@digi4care/astro-google-tagmanager";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import SearchModal from "./helpers/SearchModal";

// font families - extract font names for Font component (filter out type keys)
const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type")
);
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string | ImageMetadata;
  noindex?: boolean;
  canonical?: string;
  lang?: string;
}
// distructure frontmatters
const { title, meta_title, description, image, noindex, canonical, lang } =
  Astro.props;

const imageSrc = typeof image === "object" ? image.src : image;
const language = lang || getLangFromUrl(Astro.url);
const canonicalUrl = canonical || `${config.site.base_url}${stripHtmlExt(Astro.url.pathname) === "/" ? "" : stripHtmlExt(Astro.url.pathname)}`;
---

<!doctype html>
<html lang={language}>
  <head>
    <!-- google tag manager -->
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanager id={config.google_tag_manager.gtm_id} />
      )
    }

    <!-- favicon -->
    <link rel="shortcut icon" href={config.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-name" content="bexer-astro" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- google font css - Astro 6 built-in Font API -->
    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return <Font cssVariable={cssVar} preload />;
      })
    }

    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <!-- title -->
    <title>
      {plainify(meta_title ? meta_title : title ? title : config.site.title)}
    </title>

    <!-- canonical url -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- noindex robots -->
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- meta-description -->
    <meta
      name="description"
      content={plainify(
        description ? description : config.metadata.meta_description
      )}
    />

    <ClientRouter />

    <!-- author from config.json -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- og-title -->
    <meta
      property="og:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title
      )}
    />

    <!-- og-description -->
    <meta
      property="og:description"
      content={plainify(
        description ? description : config.metadata.meta_description
      )}
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- twitter-title -->
    <meta
      name="twitter:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title
      )}
    />

    <!-- twitter-description -->
    <meta
      name="twitter:description"
      content={plainify(
        description ? description : config.metadata.meta_description
      )}
    />

    <!-- og-image -->
    <meta
      property="og:image"
      content={`${config.site.base_url}${
        imageSrc ? imageSrc : config.metadata.meta_image
      }`}
    />

    <!-- twitter-image -->
    <meta
      name="twitter:image"
      content={`${config.site.base_url}${
        imageSrc ? imageSrc : config.metadata.meta_image
      }`}
    />
    <meta name="twitter:card" content="summary_large_image" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "@id": "https://firerisknorth.com/#organization",
        name: config.site.title,
        url: config.site.base_url,
        telephone: config.params.phone,
        email: config.params.email,
        address: {
          "@type": "PostalAddress",
          streetAddress: "Bartle House, Oxford Court",
          addressLocality: "Manchester",
          addressRegion: "Greater Manchester",
          postalCode: "M2 3WQ",
          addressCountry: "GB",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: 53.4808,
          longitude: -2.2426,
        },
        openingHoursSpecification: {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
          ],
          opens: "09:00",
          closes: "17:00",
        },
        areaServed: {
          "@type": "GeoCircle",
          geoMidpoint: {
            "@type": "GeoCoordinates",
            latitude: 53.4808,
            longitude: -2.2426,
          },
          geoRadius: "80000",
        },
        serviceType: [
          "Fire Risk Assessment",
          "Fire Alarm Testing",
          "Fire Extinguisher Servicing",
          "Emergency Light Testing",
          "Fire Door Inspection",
          "Fire Door Surveying",
          "Fire Strategy",
        ],
        image: `${config.site.base_url}${config.metadata.meta_image}`,
        priceRange: "££",
      })}
    />
  </head>
  <body class="overflow-x-hidden leading-5.5 relative">
    {/* google tag manager noscript */}
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanagerNoscript id={config.google_tag_manager.gtm_id} />
      )
    }

    <TwSizeIndicator />
    <Header />
    <SearchModal lang={language} client:idle />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
