---
import config from "@/config/config.json";
import { getTranslations } from "@/lib/utils/languageParser";

export interface Props {
  title?: string;
}

const { title } = Astro.props;
const { contact_form_action } = config.params;
const lang = Astro.params.lang as string;
const {
  send_message,
  placeholder_name,
  placeholder_email,
  placeholder_subject,
  placeholder_message,
  placeholder_phone,
  quick_contact,
} = await getTranslations(lang);
---

<div class="bg-white dark:bg-black px-8 py-10 box-shadow mb-12">
  <h5 class="mb-5">{title || quick_contact}</h5>
  <form action={contact_form_action}>
    <input
      type="text"
      name="name"
      id="name"
      class="form-input"
      placeholder={placeholder_name}
      required
    />
    <input
      type="email"
      name="mail"
      id="mail"
      class="form-input"
      placeholder={placeholder_email}
      required
    />
    <input
      type="tel"
      name="phone"
      id="phone"
      class="form-input"
      placeholder={placeholder_phone}
      required
    />
    <input
      type="text"
      name="subject"
      id="subject"
      class="form-input"
      placeholder={placeholder_subject}
      required
    />
    <textarea
      name="message"
      id="message"
      class="form-input"
      placeholder={placeholder_message}
      rows="6"
      required></textarea>
    <button type="submit" value="send" class="btn btn-primary">
      {send_message}
    </button>
  </form>
</div>
