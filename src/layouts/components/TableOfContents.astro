---
export interface Props {
  items: { label: string; href: string }[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <div class="w-full bg-[#f8f9fa] dark:bg-darkmode-light rounded-3xl p-10 relative overflow-hidden shadow-sm border border-gray-100 dark:border-darkmode-border">
      <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-linear-to-b from-[#dc2626] to-[#b91c1c]" />

      <p class="text-2xl font-bold text-[#111827] dark:text-darkmode-text-dark mb-8 px-4">
        What's Covered in This Guide
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-y-6 gap-x-12 px-4">
        {items.map((item) => (
          <a
            href={item.href}
            class="flex items-center group md:[&:last-child:nth-child(3n-2)]:col-span-3 md:[&:last-child:nth-child(3n-1)]:col-span-2"
          >
            <span class="text-[#dc2626] mr-2 transition-transform group-hover:translate-x-1">
              &rarr;
            </span>
            <span class="text-[#004a99] dark:text-blue-400 underline underline-offset-4 decoration-1 hover:text-[#003366] dark:hover:text-blue-300">
              {item.label}
            </span>
          </a>
        ))}
      </div>
    </div>
  )
}
