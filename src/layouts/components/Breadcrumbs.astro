---
import {
  getLangFromUrl,
  slugSelector,
  stripHtmlExt,
  supportedLang,
} from "@/lib/utils/languageParser";
import { humanize } from "@/lib/utils/textConverter";

const { className }: { className?: string } = Astro.props;

const baseUrl = "https://firerisknorth.com";

const paths = stripHtmlExt(Astro.url.pathname)
  .split("/")
  .filter((x) => x);

let lang = getLangFromUrl(Astro.url);
if (supportedLang.includes(paths[0])) {
  lang = paths.shift()!;
}

let baseHref = lang ? `/${lang}` : "/";
let parts = [
  {
    label: "Home",
    href: slugSelector("/", lang),
    "aria-label":
      stripHtmlExt(Astro.url.pathname) === baseHref ? "page" : undefined,
  },
];

paths.forEach((label: string, i: number) => {
  const href = slugSelector(`/${paths.slice(0, i + 1).join("/")}`, lang);
  label !== "page" &&
    parts.push({
      label: humanize(label.replace(/[-_]/g, " ")) || "",
      href,
      "aria-label":
        stripHtmlExt(Astro.url.pathname) === href ? "page" : undefined,
    });
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: parts.map((part, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: part.label,
    item: `${baseUrl}${part.href}`,
  })),
};
---

<nav aria-label="Breadcrumb" class={className}>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <ol class="inline-flex">
    {
      parts.map(({ label, ...attrs }, index) => (
        <li class="mx-1 capitalize">
          {index > 0 && <span class="inline-block mr-1">/</span>}
          {index !== parts.length - 1 ? (
            <a
              class="text-primary-on-dark dark:text-darkmode-primary"
              {...attrs}
            >
              {label}
            </a>
          ) : (
            <span class="text-light dark:text-darkmode-text">{label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
