---
export interface Props {
  data: {
    heading: string;
    description?: string;
    items: {
      year: string;
      title: string;
      description: string;
    }[];
  };
}

const { data } = Astro.props;
const latestYear = data.items[data.items.length - 1]?.year;
---

<section
  id="legislation"
  class="py-16 lg:py-24 bg-slate-50 dark:bg-darkmode-dark/50 scroll-mt-20 lg:scroll-mt-24"
>
  <div class="container">
    <div class="text-center mb-12">
      <h3
        class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-darkmode-text-dark tracking-tight"
      >
        {data.heading}
      </h3>
      {
        data.description && (
          <p class="mt-4 text-slate-600 dark:text-darkmode-text max-w-2xl mx-auto leading-relaxed">
            {data.description}
          </p>
        )
      }
      <div class="mt-4 mx-auto w-20 h-1 bg-orange-500 rounded-full"></div>
    </div>

    <div class="relative max-w-4xl mx-auto">
      <div
        class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-linear-to-b from-orange-500 to-red-500 md:-translate-x-px"
      >
      </div>

      {
        data.items.map((item, i) => {
          const isEven = i % 2 === 0;
          const isLatest = item.year === latestYear;
          return (
            <div
              class:list={[
                "relative flex items-start mb-8 last:mb-0",
                isEven ? "md:flex-row" : "md:flex-row-reverse",
              ]}
            >
              <div class="absolute left-4 md:left-1/2 -translate-x-1/2 z-10">
                <div
                  class:list={[
                    "w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold",
                    isLatest
                      ? "bg-linear-to-br from-orange-500 to-red-500 text-white shadow-lg shadow-orange-200 dark:shadow-none ring-4 ring-orange-100 dark:ring-orange-900/40"
                      : "bg-white dark:bg-darkmode-light border-2 border-orange-400 dark:border-orange-700 text-orange-700 dark:text-orange-400",
                  ]}
                >
                  {isLatest ? "★" : ""}
                </div>
              </div>

              <div
                class:list={[
                  "ml-12 md:ml-0 md:w-[calc(50%-2rem)]",
                  isEven ? "md:pr-8 md:text-right" : "md:pl-8 md:text-left",
                ]}
              >
                <div
                  class:list={[
                    "bg-white dark:bg-darkmode-light border rounded-xl p-5 text-left",
                    isLatest
                      ? "border-orange-300 dark:border-orange-700 shadow-lg shadow-orange-100 dark:shadow-none"
                      : "border-gray-100 dark:border-darkmode-border",
                  ]}
                >
                  <div class="flex items-center gap-3 mb-2">
                    <span
                      class:list={[
                        "inline-block px-3 py-1 rounded-full text-sm font-bold",
                        isLatest
                          ? "bg-linear-to-r from-orange-500 to-red-500 text-white"
                          : "bg-orange-50 dark:bg-orange-900/20 text-orange-700 dark:text-orange-400",
                      ]}
                    >
                      {item.year}
                    </span>
                    {isLatest && (
                      <span class="text-xs font-semibold text-orange-700 dark:text-orange-400 uppercase tracking-wider">
                        Latest
                      </span>
                    )}
                  </div>
                  <h3 class="font-bold text-slate-900 dark:text-darkmode-text-dark mb-1">
                    {item.title}
                  </h3>
                  <p class="text-sm text-slate-500 dark:text-darkmode-text leading-relaxed">
                    {item.description}
                  </p>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
