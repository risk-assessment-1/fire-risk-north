---
export interface Props {
  data: {
    heading: string;
    description?: string;
    regions?: {
      title: string;
      areas: string;
    }[];
    locations?: {
      name: string;
    }[];
  };
}

const { data } = Astro.props;
---

<section id="areas-covered" class="py-16 lg:py-24 bg-slate-50 dark:bg-darkmode-dark/50 scroll-mt-20 lg:scroll-mt-24">
  <div class="container">
    <div class="text-center mb-12">
      <h3 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-darkmode-text-dark tracking-tight">
        {data.heading}
      </h3>
      {
        data.description && (
          <p class="mt-4 text-lg text-slate-600 dark:text-darkmode-text max-w-3xl mx-auto leading-relaxed">
            {data.description}
          </p>
        )
      }
      <div class="mt-4 mx-auto w-20 h-1 bg-orange-500 rounded-full"></div>
    </div>

    {data.regions && data.regions.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {data.regions.map((region) => (
          <div class="bg-white dark:bg-darkmode-light border border-gray-100 dark:border-darkmode-border rounded-xl p-6 hover:shadow-lg hover:shadow-orange-100 dark:hover:shadow-none transition-shadow duration-300">
            <h4 class="text-lg font-bold text-slate-900 dark:text-darkmode-text-dark mb-2">
              {region.title}
            </h4>
            <p class="text-slate-600 dark:text-darkmode-text text-sm leading-relaxed">
              {region.areas}
            </p>
          </div>
        ))}
      </div>
    )}

    {data.locations && data.locations.length > 0 && (
      <div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          {data.locations.map((loc) => (
            <div class="bg-white dark:bg-darkmode-light border border-gray-100 dark:border-darkmode-border rounded-lg px-4 py-3 text-center text-sm font-medium text-slate-700 dark:text-darkmode-text hover:border-orange-300 dark:hover:border-orange-700 hover:text-orange-600 dark:hover:text-orange-400 transition-colors duration-200">
              {loc.name}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
