---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
import {
  getLangFromUrl,
  getTranslations,
  slugSelector,
} from "@/lib/utils/languageParser";
import { markdownify, plainify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  services: CollectionEntry<"services">[];
};

const { services } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const { read_more } = await getTranslations(lang as string);

const priorityOrder = [
  "fire-risk-assessment",
  "fire-alarm-testing",
  "fire-extinguisher-servicing",
  "fire-strategy",
];

const sortedServices = [...services].sort((a, b) => {
  const slugA = a.id.split("/").pop()?.replace(/\.md$/, "") ?? "";
  const slugB = b.id.split("/").pop()?.replace(/\.md$/, "") ?? "";
  const idxA = priorityOrder.indexOf(slugA);
  const idxB = priorityOrder.indexOf(slugB);
  const pA = idxA === -1 ? priorityOrder.length : idxA;
  const pB = idxB === -1 ? priorityOrder.length : idxB;
  return pA - pB;
});
---

<div class="container">
  <div
    class="services-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
  >
    {
      sortedServices?.map((service, index) => {
        const slugParts = service.id.split("/");
        slugParts[0] = "services";
        const modifiedSlug = slugParts.join("/");
        service.id = modifiedSlug;

        const isWide = index === 0 || index === 3;

        return (
          <div class={isWide ? "lg:col-span-2" : "lg:col-span-1"}>
            <div class="box-shadow">
              {service.data.image && (
                <ImageMod
                  src={service.data.image}
                  class={`object-cover object-top w-full h-57.5`}
                  alt={service.data.title}
                  width={isWide ? 880 : 440}
                  height={230}
                  fit="cover"
                  sizes={
                    isWide
                      ? "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 66vw"
                      : "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  }
                  widths={isWide ? [440, 880] : [440, 880]}
                />
              )}
              <div class="relative">
                {service.data.icon && (
                  <div class="bg-primary dark:bg-darkmode-primary rounded-full w-15 h-15 flex justify-center items-center absolute -top-24 left-4">
                    <DynamicIcon
                      icon={service.data.icon}
                      className="text-white text-3xl"
                    />
                  </div>
                )}

                <div class="p-4 bg-white dark:bg-darkmode-light">
                  <p class="heading h5">
                    <a
                      href={slugSelector(`/${service.id}`, lang)}
                      class="text-text-dark dark:text-darkmode-text-dark hover:text-primary dark:hover:text-darkmode-primary duration-200"
                      set:html={markdownify(service.data.title)}
                    />
                  </p>
                  {service?.body && (
                    <p
                      class="mt-2 mb-4 line-clamp-2"
                      set:html={plainify(service?.body)}
                    />
                  )}
                  <a
                    href={slugSelector(`/${service.id}`, lang)}
                    class="pl-0! btn btn-arrow"
                  >
                    {read_more}
                    <span class="sr-only">{plainify(service.data.title)}</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        );
      })
    }
  </div>
</div>
