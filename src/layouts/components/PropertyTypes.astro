---
import HomeIcon from "@/assets/icons/home.svg";
import BuildingIcon from "@/assets/icons/building-2.svg";
import UsersIcon from "@/assets/icons/users.svg";
import DoorOpenIcon from "@/assets/icons/door-open.svg";
import UtensilsIcon from "@/assets/icons/utensils.svg";
import HeartPulseIcon from "@/assets/icons/heart-pulse.svg";
import LandmarkIcon from "@/assets/icons/landmark.svg";
import SearchIcon from "@/assets/icons/search.svg";
import ShieldCheckIcon from "@/assets/icons/shield-check.svg";
import ClipboardListIcon from "@/assets/icons/clipboard-list.svg";
import HelpCircleIcon from "@/assets/icons/help-circle.svg";

export interface Props {
  data: {
    heading: string;
    subtitle?: string;
    types: {
      title: string;
      description: string;
      icon: string;
      href: string;
    }[];
    cta_label?: string;
    cta_href?: string;
  };
}

const { data } = Astro.props;

const iconMap: Record<string, any> = {
  "building-2": BuildingIcon,
  home: HomeIcon,
  landmark: LandmarkIcon,
  utensils: UtensilsIcon,
  "heart-pulse": HeartPulseIcon,
  users: UsersIcon,
  "door-open": DoorOpenIcon,
  "shield-check": ShieldCheckIcon,
  "clipboard-list": ClipboardListIcon,
  search: SearchIcon,
  "help-circle": HelpCircleIcon,
};
---

<section
  id="property-types"
  class="py-16 lg:py-24 bg-slate-50 dark:bg-darkmode-dark/50 scroll-mt-20 lg:scroll-mt-24"
>
  <div class="container">
    <div class="text-center mb-12">
      <h3
        class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-darkmode-text-dark tracking-tight"
      >
        {data.heading}
      </h3>
      {
        data.subtitle && (
          <p class="mt-4 text-lg text-slate-600 dark:text-darkmode-text max-w-3xl mx-auto leading-relaxed">
            {data.subtitle}
          </p>
        )
      }
      <div class="mt-4 mx-auto w-20 h-1 bg-orange-500 rounded-full"></div>
    </div>

    <div
      class="types-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-8 gap-6"
    >
      {
        data.types.map((type) => {
          const IconComponent = iconMap[type.icon] || null;

          return (
            <a
              href={type.href}
              class="group bg-white dark:bg-darkmode-light border border-gray-100 dark:border-darkmode-border rounded-xl p-6 hover:shadow-lg hover:shadow-orange-100 dark:hover:shadow-none transition-all duration-300 hover:border-orange-200 dark:hover:border-orange-800 lg:col-span-2"
            >
              {IconComponent && (
                <div class="w-10 h-10 rounded-lg bg-orange-50 dark:bg-orange-900/20 flex items-center justify-center text-orange-600 dark:text-orange-400 mb-3">
                  <IconComponent width={24} height={24} />
                </div>
              )}
              <h4 class="text-base font-bold text-slate-900 dark:text-darkmode-text-dark mb-1 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors">
                {type.title}
              </h4>
              <p class="text-slate-500 dark:text-darkmode-text text-sm leading-relaxed">
                {type.description}
              </p>
              <div class="mt-3 text-sm font-medium text-orange-600 dark:text-orange-400 flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                Learn more
                <svg
                  class="w-4 h-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </>
                </svg>
              </div>
            </a>
          );
        })
      }
    </div>

    {
      data.cta_label && data.cta_href && (
        <div class="text-center mt-10">
          <a
            href={data.cta_href}
            class="inline-flex items-center gap-2 text-orange-600 dark:text-orange-400 font-semibold hover:text-orange-700 dark:hover:text-orange-300 transition-colors"
          >
            {data.cta_label}
            <svg
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </>
            </svg>
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  @media (min-width: 1024px) {
    .types-grid > a:last-child:nth-child(4n-3) {
      grid-column-end: 6;
    }

    .types-grid > a:nth-last-child(2):nth-child(4n-3) {
      grid-column-end: 5;
    }

    .types-grid > a:nth-last-child(3):nth-child(4n-3) {
      grid-column-end: 4;
    }
  }
</style>
