---
import type { ImageMetadata } from "astro";
import ImageMod from "@/components/ImageMod.astro";

export interface Props {
  title: string;
  subtitle: string;
  description: string;
  image: string | ImageMetadata;
  price?: string;
  badges?: { label: string }[];
}

const { title, subtitle, description, image, price, badges } = Astro.props;
---

<section
  class="py-12 lg:py-20 bg-linear-to-b from-slate-50 to-white dark:from-darkmode-dark dark:to-darkmode-body"
>
  <div class="container">
    <div
      class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
    >
      <div class="space-y-6">
        <div
          class="inline-flex items-center bg-white dark:bg-darkmode-light rounded-full px-4 py-2 shadow-sm border border-gray-100 dark:border-darkmode-border"
        >
          <div class="flex text-yellow-400 mr-2">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path></svg
            >
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path></svg
            >
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path></svg
            >
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path></svg
            >
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path></svg
            >
          </div>
          <span
            class="font-bold text-slate-900 dark:text-darkmode-text-dark mr-1"
            >4.9</span
          >
          <span class="text-text-light">| 500+ Reviews</span>
        </div>

        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-darkmode-text tracking-tight leading-tight"
        >
          {title}<br />
          <span class="text-orange-700">{subtitle}</span>
        </h1>

        {
          price && (
            <div class="inline-block bg-orange-500 text-white font-bold py-2 px-6 rounded-full shadow-lg shadow-orange-200">
              {price}
            </div>
          )
        }

        <p
          class="text-slate-500 dark:text-darkmode-text-dark/70 text-lg leading-relaxed max-w-xl"
          set:html={description}
        />

        <div class="flex flex-wrap gap-4 pt-4">
          <a
            href="/contact"
            class="bg-linear-to-r from-orange-500 to-red-500 text-white font-bold py-4 px-8 rounded-lg shadow-xl shadow-orange-200 hover:scale-105 transition-transform"
          >
            Get a Free Quote
          </a>
          <a
            href="/contact"
            class="border-2 border-slate-900 dark:border-darkmode-text text-slate-900 dark:text-darkmode-text font-bold py-4 px-8 rounded-lg hover:bg-slate-50 dark:hover:bg-darkmode-light transition-colors"
          >
            Contact Us
          </a>
        </div>

        {
          badges && badges.length > 0 && (
            <div class="flex flex-wrap gap-6 pt-6">
              {badges.map((badge) => (
                <div class="flex items-center text-slate-900 dark:text-darkmode-text font-semibold">
                  <span class="w-6 h-6 bg-emerald-400 rounded-full flex items-center justify-center mr-2">
                    <svg
                      class="w-4 h-4 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                  </span>
                  {badge.label}
                </div>
              ))}
            </div>
          )
        }
      </div>

      <div class="relative">
        <div class="rounded-3xl overflow-hidden shadow-2xl">
          <ImageMod
            src={image}
            alt={title}
            width={800}
            height={450}
            fit="cover"
            class="w-full h-112.5 object-cover"
            sizes="(max-width: 768px) 90vw, (max-width: 1280px) 50vw, 800px"
            widths={[400, 800]}
          />
        </div>

        <div
          class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-11/12 bg-white dark:bg-darkmode-light rounded-2xl shadow-2xl p-8 flex justify-around items-center border border-gray-50 dark:border-darkmode-border"
        >
          <div class="text-center">
            <div class="text-orange-700 text-3xl font-extrabold">25+</div>
            <div
              class="text-text-light text-xs font-bold uppercase tracking-wider mt-1"
            >
              Years
            </div>
          </div>
          <div class="h-12 w-px bg-gray-100 dark:bg-darkmode-border"></div>
          <div class="text-center">
            <div class="text-orange-700 text-3xl font-extrabold">512+</div>
            <div
              class="text-text-light text-xs font-bold uppercase tracking-wider mt-1"
            >
              Projects
            </div>
          </div>
          <div class="h-12 w-px bg-gray-100 dark:bg-darkmode-border"></div>
          <div class="text-center">
            <div class="text-orange-700 text-3xl font-extrabold">24hr</div>
            <div
              class="text-text-light text-xs font-bold uppercase tracking-wider mt-1"
            >
              Turnaround
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
