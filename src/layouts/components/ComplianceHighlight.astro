---
export interface Props {
  id?: string;
  data: {
    heading: string;
    heading_accent?: string;
    subtitle?: string;
    highlights: {
      title?: string;
      stat?: string;
      description: string;
    }[];
    body: string;
    cta?: {
      label: string;
      href: string;
    };
  };
}

const { id, data } = Astro.props;
---

<section id={id} class="py-16 lg:py-24 scroll-mt-20 lg:scroll-mt-24">
  <div class="container">
    <div class="text-center mb-12">
      <h3
        class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-darkmode-text-dark leading-tight mb-6"
      >
        {data.heading}
        {
          data.heading_accent && (
            <span class="text-[#f8714b]"> {data.heading_accent}</span>
          )
        }
      </h3>
      {
        data.subtitle && (
          <p class="text-lg text-slate-600 dark:text-darkmode-text max-w-3xl mx-auto leading-relaxed">
            {data.subtitle}
          </p>
        )
      }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {
        data.highlights.map((item) => (
          <div class="bg-white dark:bg-darkmode-light border border-gray-200 dark:border-darkmode-border rounded-xl p-8 text-center flex flex-col justify-center min-h-70 shadow-sm md:[&:last-child:nth-child(3n-2)]:col-span-3 md:[&:last-child:nth-child(3n-1)]:col-span-2">
            {(item.title || item.stat) && (
              <h3
                class:list={[
                  "font-extrabold text-[#f8714b] mb-4 uppercase tracking-tight leading-none",
                  item.stat ? "text-5xl" : "text-3xl",
                ]}
              >
                {item.stat || item.title}
              </h3>
            )}
            <p class="text-slate-900 dark:text-darkmode-text-dark font-semibold text-base">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="max-w-4xl mx-auto mb-10">
      <p
        class="text-slate-600 dark:text-darkmode-text leading-8 text-lg text-center"
        set:html={data.body}
      />
    </div>

    {
      data.cta && (
        <div class="flex justify-center">
          <a
            href={data.cta.href}
            class="inline-flex items-center justify-center px-10 py-5 bg-linear-to-r from-[#f8714b] to-[#ef4444] text-white text-xl font-bold rounded-xl shadow-xl hover:opacity-90 transition-all duration-200 group"
          >
            {data.cta.label}
            <svg
              class="ml-3 w-6 h-6 transition-transform group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"
              />
            </svg>
          </a>
        </div>
      )
    }
  </div>
</section>
