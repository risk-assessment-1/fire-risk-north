---
export interface Props {
  data: {
    heading: string;
    description?: string;
    steps: {
      number: number;
      title: string;
      description: string;
      icon: string;
    }[];
  };
}

const { data } = Astro.props;
const stepCount = data.steps.length;
const lgCols = stepCount > 5 ? "lg:grid-cols-6" : "lg:grid-cols-5";
---

<section
  id="process"
  class="py-16 lg:py-24 bg-slate-50 dark:bg-darkmode-dark/50 scroll-mt-20 lg:scroll-mt-24"
>
  <div class="container">
    <div class="text-center mb-16">
      <h3
        class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-darkmode-text-dark mb-6"
      >
        {data.heading}
      </h3>
      {
        data.description && (
          <p class="text-lg text-slate-600 dark:text-darkmode-text max-w-3xl mx-auto leading-relaxed">
            {data.description}
          </p>
        )
      }
    </div>

    <div class="relative">
      <div
        class={`hidden lg:block absolute top-15 ${stepCount > 5 ? "left-[8%] right-[8%]" : "left-[10%] right-[10%]"} h-0.5 bg-linear-to-r from-orange-400 via-orange-500 to-orange-400 dark:from-orange-700 dark:via-orange-700 dark:to-orange-700 z-0`}
      >
      </div>

      <div
        class={`grid grid-cols-1 md:grid-cols-3 ${lgCols} gap-8 relative z-10`}
      >
        {
          data.steps.map((step) => (
            <div class="flex flex-col items-center">
              <div class="w-24 h-24 min-w-24 min-h-24 max-w-24 max-h-24 aspect-square bg-linear-to-br from-[#f8714b] to-[#e15b31] rounded-full flex items-center justify-center text-white text-4xl font-bold -mb-12 z-20 shadow-lg border-4 border-white dark:border-darkmode-light">
                {step.number}
              </div>
              <div class="bg-white dark:bg-darkmode-light rounded-2xl p-8 pt-16 flex flex-col items-center text-center h-full border border-gray-100 dark:border-darkmode-border">
                <h3 class="text-[#004a99] dark:text-blue-400 font-bold text-lg mb-4">
                  {step.title}
                </h3>
                <p class="text-slate-500 dark:text-darkmode-text text-sm leading-relaxed">
                  {step.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
