---
import ImageMod from "@/components/ImageMod.astro";
import HeroSection from "@/components/HeroSection.astro";
import SidebarServices from "@/components/SidebarServices.astro";
import FiveStepsFRA from "@/components/FiveStepsFRA.astro";
import HazardCards from "@/components/HazardCards.astro";
import FRACosts from "@/components/FRACosts.astro";
import FAQSection from "@/components/FAQSection.astro";
import ComplianceHighlight from "@/components/ComplianceHighlight.astro";
import CTASection from "@/components/CTASection.astro";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import {
  getLangFromUrl,
  getTranslations,
  supportedLang,
} from "@/lib/utils/languageParser";
import PageHeader from "@/partials/PageHeader.astro";
import { render } from "astro:content";

export async function getStaticPaths() {
  const paths = await Promise.all(
    supportedLang.map(async (lang) => {
      const fraPages = await getSinglePage(
        "fire-risk-assessment",
        lang as string,
      );

      return fraPages.map((page) => ({
        params: {
          lang: lang || undefined,
          single: page.id.split("/").pop(),
        },
        props: {
          page,
        },
      }));
    }),
  );
  return paths.flat();
}

const { page } = Astro.props;
const { lang } = Astro.params;
const {
  title,
  meta_title,
  description,
  image,
  hero,
  compliance_highlight,
  five_steps_fra,
  hazard_cards,
  fra_costs,
  faq_section,
} = page.data;
const { Content } = await render(page);
const land = getLangFromUrl(Astro.url);

const allFraPages = await getSinglePage("fire-risk-assessment", land as string);
const fraSlugs = allFraPages
  .map((p) => p.id.split("/").pop())
  .filter(Boolean) as string[];

const currentFraSlug = page.id.split("/").pop() || "";

await getTranslations(lang as string);
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  {
    hero && hero.enable && (
      <HeroSection
        title={hero.title || title}
        subtitle={hero.subtitle || ""}
        description={hero.description || description}
        image={hero.image || image || ""}
        price={hero.price}
        badges={hero.badges}
      />
    )
  }
  {!hero || !hero.enable ? <PageHeader title={title} /> : null}

  <section
    id="service-overview"
    class="section py-0! scroll-mt-20 lg:scroll-mt-24 container"
  >
    <div class="container">
      <div class="row mx-auto">
        <div class="lg:col-8">
          {
            (!hero || !hero.enable) && image && (
              <ImageMod
                src={image}
                class="mb-10 w-full"
                width={1000}
                height={900}
                alt={title}
              />
            )
          }
          <div class="content">
            <Content />
          </div>
        </div>

        <aside class="lg:col-4">
          <div class="lg:sticky lg:top-28">
            <SidebarServices
              slugs={fraSlugs}
              currentSlug={currentFraSlug}
              basePath="/services/fire-risk-assessment"
              title="Building Types"
            />
          </div>
        </aside>
      </div>
    </div>
  </section>

  {
    compliance_highlight && compliance_highlight.enable && (
      <ComplianceHighlight data={compliance_highlight} />
    )
  }

  {
    five_steps_fra && five_steps_fra.enable && (
      <FiveStepsFRA data={five_steps_fra} />
    )
  }

  {hazard_cards && hazard_cards.enable && <HazardCards data={hazard_cards} />}

  {fra_costs && fra_costs.enable && <FRACosts data={fra_costs} />}

  {faq_section && faq_section.enable && <FAQSection data={faq_section} />}

  <CTASection
    title={`Ready to Get Your ${title}?`}
    tag={`Professional service from BAFE-accredited engineers. 24-hour turnaround. ${hero?.price || "Contact us for pricing"}.`}
  />
</Base>
