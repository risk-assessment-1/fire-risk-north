---
import ServiceCard from "@/components/ServiceCard.astro";
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import { getLangFromUrl, supportedLang } from "@/lib/utils/languageParser";
import PageHeader from "@/partials/PageHeader.astro";
import { markdownify } from "@/lib/utils/textConverter";

export function getStaticPaths() {
  const paths = supportedLang.map((lang) => ({
    params: { lang: lang || undefined },
  }));
  return paths;
}

const lang = getLangFromUrl(Astro.url);

const fraPages = await getSinglePage("fire-risk-assessment", lang as string);
---

<Base
  title="Fire Risk Assessment"
  meta_title="Fire Risk Assessment by Property Type - Fire Assessment North"
  description="Professional fire risk assessments for all property types including flats, offices, HMOs, hotels, schools, care homes and more."
  image="/images/fire-risk-assessment/fire-risk-assessment.jpg"
>
  <PageHeader title="Fire Risk Assessment" />

  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-10">
          <div class="content text-center mb-12">
            <p class="text-lg text-text-dark/70 dark:text-darkmode-text-dark/70">
              We provide specialist fire risk assessments tailored to your property type. Select your property category below to learn more about our assessment process and how we can help you achieve compliance.
            </p>
          </div>
        </div>
      </div>
      <div class="row g-4">
        {
          fraPages.map((page) => {
            const slug = page.id.split("/").pop();
            return (
              <div class="lg:col-4 sm:col-6 mb-4 lg:mb-0">
                <div class="box-shadow">
                  <div class="p-6 bg-white dark:bg-darkmode-light min-h-[200px] flex flex-col justify-between">
                    <div>
                      <h5>
                        <a
                          href={`/services/fire-risk-assessment/${slug}`}
                          class="text-text-dark dark:text-darkmode-text-dark hover:text-primary dark:hover:text-darkmode-primary duration-200"
                          set:html={markdownify(page.data.title)}
                        />
                      </h5>
                      {page?.body && (
                        <p class="mt-2 mb-4 line-clamp-3 text-text-dark/70 dark:text-darkmode-text-dark/70">
                          {page.data.description}
                        </p>
                      )}
                    </div>
                    <a
                      href={`/services/fire-risk-assessment/${slug}`}
                      class="btn btn-arrow mt-4"
                    >
                      Read More
                    </a>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>
</Base>
