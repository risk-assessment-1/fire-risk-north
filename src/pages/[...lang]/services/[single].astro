---
import ImageMod from "@/components/ImageMod.astro";
import HeroSection from "@/components/HeroSection.astro";
import SidebarServices from "@/components/SidebarServices.astro";
import WhoNeedsFRA from "@/components/WhoNeedsFRA.astro";
import FiveStepsFRA from "@/components/FiveStepsFRA.astro";
import FRACosts from "@/components/FRACosts.astro";
import LegislationTimeline from "@/components/LegislationTimeline.astro";
import FAQSection from "@/components/FAQSection.astro";
import CTASection from "@/components/CTASection.astro";
import HazardCards from "@/components/HazardCards.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import {
  getLangFromUrl,
  getTranslations,
  supportedLang,
} from "@/lib/utils/languageParser";
import { markdownify } from "@/lib/utils/textConverter";
import PageHeader from "@/partials/PageHeader.astro";
import { render } from "astro:content";
import { FaDownload, FaRegFilePdf } from "react-icons/fa6";

export async function getStaticPaths() {
  const paths = await Promise.all(
    supportedLang.map(async (lang) => {
      const services = await getSinglePage("services", lang as string);

      return services.map((service) => ({
        params: {
          lang: lang || undefined,
          single: service.id.split("/").pop(),
        },
        props: {
          service,
        },
      }));
    }),
  );
  return paths.flat();
}

const { service } = Astro.props;
const { lang } = Astro.params;
const {
  title,
  meta_title,
  description,
  image,
  pdf,
  hero,
  who_needs_fra,
  five_steps_fra,
  fra_costs,
  legislation_timeline,
  hazard_cards,
  faq_section,
} = service.data;
const { Content } = await render(service);
const land = getLangFromUrl(Astro.url);
const allServices = await getSinglePage("services", land as string);

const serviceSlugs = allServices.map((service) => {
  const parts = service.id.split("/");
  return parts[1];
});

const currentServiceSlug = service.id.split("/")[1];

const { download_pdf, our_services } = await getTranslations(lang as string);

const tocItems: { label: string; href: string }[] = [];
tocItems.push({ label: `What is ${title}?`, href: "#service-overview" });
if (who_needs_fra?.enable)
  tocItems.push({ label: "Who Needs This?", href: "#who-needs" });
if (five_steps_fra?.enable)
  tocItems.push({ label: five_steps_fra.heading, href: "#process" });
if (hazard_cards?.enable)
  tocItems.push({ label: hazard_cards.heading, href: "#hazards" });
if (fra_costs?.enable)
  tocItems.push({ label: fra_costs.heading, href: "#costs" });
if (legislation_timeline?.enable)
  tocItems.push({ label: legislation_timeline.heading, href: "#legislation" });
if (faq_section?.enable)
  tocItems.push({ label: faq_section.heading, href: "#faq" });
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  {
    hero && hero.enable && (
      <HeroSection
        title={hero.title || title}
        subtitle={hero.subtitle || ""}
        description={hero.description || description}
        image={hero.image || image || ""}
        price={hero.price}
        badges={hero.badges}
      />
    )
  }
  {!hero || !hero.enable ? <PageHeader title={title} /> : null}

  <section class="section py-8!">
    <div class="container">
      <TableOfContents items={tocItems} />
    </div>
  </section>

  <section
    id="service-overview"
    class="section py-0! scroll-mt-20 lg:scroll-mt-24"
  >
    <div class="container">
      <div class="row mx-auto">
        <div class="lg:col-8">
          {
            (!hero || !hero.enable) && image && (
              <ImageMod
                src={image}
                class="mb-10 w-full"
                width={1000}
                height={900}
                alt={title}
                sizes="(max-width: 768px) 90vw, (max-width: 1280px) 66vw, 1000px"
                widths={[500, 1000]}
              />
            )
          }
          <div class="content">
            <Content />
          </div>
        </div>

        <aside class="lg:col-4">
          <div class="lg:sticky lg:top-28">
            {
              pdf && pdf.enable && (
                <div class="bg-white dark:bg-black lg:px-8 py-10 box-shadow mb-12">
                  <p class="mb-5 text-h5">{download_pdf}</p>
                  <ul class="list-unstyled relative">
                    <li class="flex pb-3 mb-3 border-b border-border items-center">
                      <FaRegFilePdf className="text-primary dark:text-darkmode-primary text-4xl" />
                      <div class="ms-3">
                        <p
                          class="mb-0 text-text-dark/80 dark:text-darkmode-text-dark/80"
                          set:html={markdownify(pdf.title)}
                        />
                        <span
                          class="text-text-dark/80 dark:text-darkmode-text-dark/80"
                          set:html={markdownify(pdf.size)}
                        />
                      </div>
                      <a
                        href={pdf.file}
                        class="text-text ml-auto stretched-link"
                      >
                        <FaDownload className="text-2xl" />
                      </a>
                    </li>
                  </ul>
                </div>
              )
            }
            <SidebarServices
              slugs={serviceSlugs}
              currentSlug={currentServiceSlug}
              title={our_services}
            />
          </div>
        </aside>
      </div>
    </div>
  </section>

  {
    who_needs_fra && who_needs_fra.enable && (
      <WhoNeedsFRA data={who_needs_fra} />
    )
  }

  {
    five_steps_fra && five_steps_fra.enable && (
      <FiveStepsFRA data={five_steps_fra} />
    )
  }

  {hazard_cards && hazard_cards.enable && <HazardCards data={hazard_cards} />}

  {fra_costs && fra_costs.enable && <FRACosts data={fra_costs} />}

  {
    legislation_timeline && legislation_timeline.enable && (
      <LegislationTimeline data={legislation_timeline} />
    )
  }

  {faq_section && faq_section.enable && <FAQSection data={faq_section} />}

  <CTASection
    title={`Ready to Get Your ${title}?`}
    tag={`Professional service from BAFE-accredited engineers. 24-hour turnaround. ${hero?.price || "Contact us for pricing"}.`}
  />
</Base>
