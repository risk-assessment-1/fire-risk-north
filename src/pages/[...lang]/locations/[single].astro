---
import ImageMod from "@/components/ImageMod.astro";
import HeroSection from "@/components/HeroSection.astro";
import SidebarServices from "@/components/SidebarServices.astro";
import AreasCovered from "@/components/AreasCovered.astro";
import FiveStepsFRA from "@/components/FiveStepsFRA.astro";
import FeatureCards from "@/components/FeatureCards.astro";
import PropertyTypes from "@/components/PropertyTypes.astro";
import FAQSection from "@/components/FAQSection.astro";
import CTASection from "@/components/CTASection.astro";
import ServiceSection from "@/partials/homepage/ServiceSection.astro";
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import {
  getLangFromUrl,
  getTranslations,
  supportedLang,
} from "@/lib/utils/languageParser";
import PageHeader from "@/partials/PageHeader.astro";
import { render } from "astro:content";

export async function getStaticPaths() {
  const paths = await Promise.all(
    supportedLang.map(async (lang) => {
      const locations = await getSinglePage("locations", lang as string);

      return locations.map((location) => ({
        params: {
          lang: lang || undefined,
          single: location.id.split("/").pop(),
        },
        props: {
          location,
        },
      }));
    }),
  );
  return paths.flat();
}

const { location } = Astro.props;
const { lang } = Astro.params;
const {
  title,
  meta_title,
  description,
  image,
  hero,
  areas_covered,
  five_steps_fra,
  features,
  property_types,
  services_grid,
  faq_section,
} = location.data;
const { Content } = await render(location);
const land = getLangFromUrl(Astro.url);

const allLocations = await getSinglePage("locations", land as string);
const locationSlugs = allLocations
  .map((l) => l.id.split("/").pop())
  .filter(Boolean) as string[];

const currentLocationSlug = location.id.split("/").pop() || "";

const { our_locations } = await getTranslations(lang as string);

const serviceIndex = await getListPage("services", lang as string);
const services = await getSinglePage("services", lang as string);

const locationName = hero?.subtitle || title.replace(/.*\sin\s/i, "");
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  {
    hero && hero.enable && (
      <HeroSection
        title={hero.title || title}
        subtitle={hero.subtitle || ""}
        description={hero.description || description}
        image={hero.image || image || ""}
        price={hero.price}
        badges={hero.badges}
        secondaryHref="#faq"
      />
    )
  }
  {!hero || !hero.enable ? <PageHeader title={title} /> : null}

  <section
    id="service-overview"
    class="section container py-0! scroll-mt-20 lg:scroll-mt-24"
  >
    <div class="container">
      <div class="row mx-auto">
        <div class="lg:col-8">
          {
            (!hero || !hero.enable) && image && (
              <ImageMod
                src={image}
                class="mb-10 w-full"
                width={1000}
                height={900}
                alt={title}
                sizes="(max-width: 768px) 90vw, (max-width: 1280px) 66vw, 1000px"
                widths={[500, 1000]}
              />
            )
          }
          <div class="content">
            <Content />
          </div>
        </div>

        <aside class="lg:col-4">
          <div class="lg:sticky lg:top-28">
            <SidebarServices
              slugs={locationSlugs}
              currentSlug={currentLocationSlug}
              basePath="/locations"
              title={our_locations}
            />
          </div>
        </aside>
      </div>
    </div>
  </section>

  {
    areas_covered && areas_covered.enable && (
      <AreasCovered data={areas_covered} />
    )
  }

  {
    five_steps_fra && five_steps_fra.enable && (
      <FiveStepsFRA data={five_steps_fra} />
    )
  }

  {features && features.enable && <FeatureCards data={features} />}

  {
    services_grid && services_grid.enable && (
      <ServiceSection
        serviceIndex={serviceIndex[0]}
        services={services}
        title={`Fire Safety & Compliance Services in ${locationName}`}
        subtitle="One partner for all your property compliance needs"
      />
    )
  }

  {
    property_types && property_types.enable && (
      <PropertyTypes data={property_types} />
    )
  }

  {faq_section && faq_section.enable && <FAQSection data={faq_section} />}

  <CTASection
    title={`Ready to Get Your ${title}?`}
    tag={`Professional service from BAFE-accredited engineers. 24-hour turnaround. ${hero?.price || "Contact us for pricing"}.`}
  />
</Base>
