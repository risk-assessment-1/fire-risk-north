---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { getTranslations, supportedLang } from "@/lib/utils/languageParser";
import PageHeader from "@/partials/PageHeader.astro";
import { FaMapMarkerAlt, FaPhoneAlt } from "react-icons/fa";
import { FaEnvelope } from "react-icons/fa6";

export function getStaticPaths() {
  const paths = supportedLang.map((lang) => ({
    params: { lang: lang || undefined },
  }));
  return paths;
}

const { lang } = Astro.params;
const contact = await getListPage("contact", lang as string);

if (contact[0].data.draft) {
  return Astro.redirect("/404");
}

const { contact_form_action, address, phone, email } = config.params;
const { title, description, meta_title, image } = contact[0].data;

const {
  our_address,
  phone_number,
  message_us,
  contact_form,
  send_message,
  placeholder_name,
  placeholder_email,
  placeholder_phone,
  placeholder_service,
  placeholder_building_type,
  placeholder_location,
  placeholder_message,
  form_success,
  form_error,
} = await getTranslations(lang as string);
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <PageHeader title={title} />

  <section class="section pb-0">
    <div class="container">
      <div class="row justify-center g-5">
        <div class="col-10 sm:col-8 md:col-5">
          <iframe
            class="w-full h-96 md:h-125"
            title="Fire Assessment North office location on Google Maps"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2374.6!2d-2.2426!3d53.4808!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487bb1c0b3b3b3b3%3A0x1234567890abcdef!2sBartle%20House%2C%20Oxford%20Court%2C%20Manchester%20M2%203WQ!5e0!3m2!1sen!2suk!4v1711167419704!5m2!1sen!2suk"
            loading="lazy"></iframe>
        </div>

        <div class="col-10 sm:col-8 md:col-7">
          <h2 class="section-title">{contact_form}</h2>
          <form id="contact-form" data-action={contact_form_action} data-success={form_success} data-error={form_error} class="row">
            <div class="md:col-6">
              <input
                type="text"
                name="name"
                id="name"
                required
                class="form-input box-shadow mb-5 px-8 py-5"
                placeholder={placeholder_name}
              />
            </div>
            <div class="md:col-6">
              <input
                type="email"
                name="email"
                id="email"
                required
                class="form-input box-shadow mb-5 px-8 py-5"
                placeholder={placeholder_email}
              />
            </div>
            <div class="md:col-6">
              <input
                type="tel"
                name="phone"
                id="phone"
                class="form-input box-shadow mb-5 px-8 py-5"
                placeholder={placeholder_phone}
              />
            </div>
            <div class="md:col-6">
              <select
                name="service"
                id="service"
                class="form-input box-shadow mb-5 px-8 py-5 text-slate-500"
              >
                <option value="">{placeholder_service}</option>
                <option value="Fire Risk Assessment">Fire Risk Assessment</option>
                <option value="Fire Alarm Testing">Fire Alarm Testing</option>
                <option value="Fire Extinguisher Servicing">Fire Extinguisher Servicing</option>
                <option value="Emergency Light Testing">Emergency Light Testing</option>
                <option value="Fire Door Inspection">Fire Door Inspection</option>
                <option value="Fire Door Surveying">Fire Door Surveying</option>
                <option value="Fire Strategy">Fire Strategy</option>
              </select>
            </div>
            <div class="md:col-6">
              <select
                name="building_type"
                id="building_type"
                class="form-input box-shadow mb-5 px-8 py-5 text-slate-500"
              >
                <option value="">{placeholder_building_type}</option>
                <option value="HMO">HMO</option>
                <option value="Flats / Block of Flats">Flats / Block of Flats</option>
                <option value="Office">Office</option>
                <option value="Retail">Retail</option>
                <option value="Warehouse">Warehouse</option>
                <option value="School">School</option>
                <option value="Hospital">Hospital</option>
                <option value="Hotel">Hotel</option>
                <option value="Care Home">Care Home</option>
                <option value="High-Rise Building">High-Rise Building</option>
                <option value="Restaurant">Restaurant</option>
              </select>
            </div>
            <div class="md:col-6">
              <input
                type="text"
                name="location"
                id="location"
                class="form-input box-shadow mb-5 px-8 py-5"
                placeholder={placeholder_location}
              />
            </div>
            <div class="col-12">
              <textarea
                name="message"
                id="message"
                required
                class="form-input box-shadow mb-5 px-8 py-5"
                rows="6"
                placeholder={placeholder_message}></textarea>
            </div>
            <div class="col-12">
              <input
                type="text"
                name="_honey"
                style="display:none"
                tabindex="-1"
                autocomplete="off"
              />
            </div>
            <div class="col-12">
              <button
                type="submit"
                class="btn btn-primary hover-ripple"
              >
                {send_message}
              </button>
            </div>
            <div class="col-12">
              <p id="form-status" class="min-h-[1lh] mt-3 text-sm font-medium hidden"></p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="row justify-center g-5">
        <div class="col-10 sm:col-8 md:col-4">
          <div
            class="bg-white dark:bg-black box-shadow text-center p-5 md:p-12"
          >
            <FaMapMarkerAlt
              className="text-primary dark:text-darkmode-primary mx-auto mb-4"
              size={56}
            />

            <p class="mb-4 text-h5">{our_address}</p>
            <ul class="text-balance space-y-1">
              <li>{address}</li>
            </ul>
          </div>
        </div>
        <div class="col-10 sm:col-8 md:col-4">
          <div
            class="bg-white dark:bg-black box-shadow text-center p-5 md:p-12"
          >
            <FaPhoneAlt
              className="text-primary dark:text-darkmode-primary mx-auto mb-4"
              size={56}
            />
            <p class="mb-4 text-h5">{phone_number}</p>
            <ul class="text-balance">
              <li>{phone}</li>
            </ul>
          </div>
        </div>
        <div class="col-10 sm:col-8 md:col-4">
          <div
            class="bg-white dark:bg-black box-shadow text-center p-5 md:p-12"
          >
            <FaEnvelope
              className="text-primary dark:text-darkmode-primary mx-auto mb-4"
              size={56}
            />
            <p class="mb-4 text-h5">{message_us}</p>
            <ul class="text-balance">
              <li>{email}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const status = document.getElementById("form-status") as HTMLParagraphElement;

    if (!form || !status) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const honey = form.querySelector<HTMLInputElement>('[name="_honey"]');
      if (honey && honey.value) return;

      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const originalText = btn?.textContent || "";

      if (btn) {
        btn.disabled = true;
        btn.textContent = "Sending...";
      }

      const data: Record<string, string> = {};
      new FormData(form).forEach((value, key) => {
        if (key !== "_honey" && typeof value === "string") {
          data[key] = value;
        }
      });

      try {
        const res = await fetch(form.dataset.action || "", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          status.textContent = form.dataset.success || "Thank you! Your message has been sent successfully.";
          status.className = "min-h-[1lh] mt-3 text-sm font-medium text-green-600 dark:text-green-400";
          form.reset();
        } else {
          throw new Error(`HTTP ${res.status}`);
        }
      } catch {
        status.textContent = form.dataset.error || "Something went wrong. Please try again.";
        status.className = "min-h-[1lh] mt-3 text-sm font-medium text-red-600 dark:text-red-400";
      }

      if (btn) {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
  });
</script>
