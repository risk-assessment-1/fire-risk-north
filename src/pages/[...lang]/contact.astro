---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { getTranslations, supportedLang } from "@/lib/utils/languageParser";
import PageHeader from "@/partials/PageHeader.astro";
import { FaMapMarkerAlt, FaPhoneAlt } from "react-icons/fa";
import { FaEnvelope } from "react-icons/fa6";

export function getStaticPaths() {
  const paths = supportedLang.map((lang) => ({
    params: { lang: lang || undefined },
  }));
  return paths;
}

const { lang } = Astro.params;
const contact = await getListPage("contact", lang as string);

if (contact[0].data.draft) {
  return Astro.redirect("/404");
}

const { contact_form_action, address, phone, email } = config.params;
const { title, description, meta_title, image } = contact[0].data;

const {
  our_address,
  phone_number,
  message_us,
  contact_form,
  send_message,
  placeholder_name,
  placeholder_email,
  placeholder_subject,
  placeholder_message,
  placeholder_phone,
} = await getTranslations(lang as string);
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <PageHeader title={title} />

  <!-- contact form and map -->
  <section class="section pb-0">
    <div class="container">
      <div class="row justify-center g-5">
        <!-- google map -->
        <div class="col-10 sm:col-8 md:col-5">
          <iframe
            class="w-full h-96 md:h-125"
            title="Fire Assessment North office location on Google Maps"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2374.6!2d-2.2426!3d53.4808!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487bb1c0b3b3b3b3%3A0x1234567890abcdef!2sBartle%20House%2C%20Oxford%20Court%2C%20Manchester%20M2%203WQ!5e0!3m2!1sen!2suk!4v1711167419704!5m2!1sen!2suk"
            loading="lazy"></iframe>
        </div>

        <div class="col-10 sm:col-8 md:col-7">
          <h2 class="section-title">{contact_form}</h2>
          <form action={contact_form_action} class="row">
            <div class="md:col-6">
              <input
                type="text"
                name="name"
                id="name"
                class="form-input box-shadow mb-5 px-8 py-5"
                placeholder={placeholder_name}
              />
            </div>
            <div class="md:col-6">
              <input
                type="email"
                name="mail"
                id="mail"
                class="form-input box-shadow mb-5 px-8 py-5"
                placeholder={placeholder_email}
              />
            </div>
            <div class="md:col-6">
              <input
                type="text"
                name="phone"
                id="phone"
                class="form-input box-shadow mb-5 px-8 py-5"
                placeholder={placeholder_phone}
              />
            </div>
            <div class="md:col-6">
              <input
                type="text"
                name="subject"
                id="subject"
                class="form-input box-shadow mb-5 px-8 py-5"
                placeholder={placeholder_subject}
              />
            </div>
            <div class="col-12">
              <textarea
                name="message"
                id="message"
                class="form-input box-shadow mb-5 px-8 py-5"
                rows="6"
                placeholder={placeholder_message}></textarea>
            </div>
            <div class="col-12">
              <button
                type="submit"
                value="send"
                class="btn btn-primary hover-ripple"
              >
                {send_message}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
  <!-- /contact form and map -->

  <!-- contact items -->
  <section class="section">
    <div class="container">
      <div class="row justify-center g-5">
        <!-- Addresses -->
        <div class="col-10 sm:col-8 md:col-4">
          <div
            class="bg-white dark:bg-black box-shadow text-center p-5 md:p-12"
          >
            <FaMapMarkerAlt
              className="text-primary dark:text-darkmode-primary mx-auto mb-4"
              size={56}
            />

            <p class="mb-4 text-h5">{our_address}</p>
            <ul class="text-balance space-y-1">
              <li>{address}</li>
            </ul>
          </div>
        </div>
        <!-- phone -->
        <div class="col-10 sm:col-8 md:col-4">
          <div
            class="bg-white dark:bg-black box-shadow text-center p-5 md:p-12"
          >
            <FaPhoneAlt
              className="text-primary dark:text-darkmode-primary mx-auto mb-4"
              size={56}
            />
            <p class="mb-4 text-h5">{phone_number}</p>
            <ul class="text-balance">
              <li>{phone}</li>
            </ul>
          </div>
        </div>
        <!-- Mail -->
        <div class="col-10 sm:col-8 md:col-4">
          <div
            class="bg-white dark:bg-black box-shadow text-center p-5 md:p-12"
          >
            <FaEnvelope
              className="text-primary dark:text-darkmode-primary mx-auto mb-4"
              size={56}
            />
            <p class="mb-4 text-h5">{message_us}</p>
            <ul class="text-balance">
              <li>{email}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /contact item -->
</Base>
